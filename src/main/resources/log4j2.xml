<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <!-- 變數定義 -->
    <Properties>
        <Property name="LOG_PATTERN">
            [%d{yyyy-MM-dd HH:mm:ss}] [%-5level] %msg%n
        </Property>
        <Property name="LOG_PATTERN_WITH_LOCATION">
            [%d{yyyy-MM-dd HH:mm:ss}] [%-5level] [%c{1}:%L] %msg%n
        </Property>
    </Properties>

    <Appenders>
        <!-- 控制台輸出 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!-- 主要日誌檔（自動按日期輪轉） -->
        <RollingFile name="RollingFile"
                     fileName="logs/app.log"
                     filePattern="logs/app-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <!-- 每天輪轉 -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <!-- 檔案大小超過 10MB 也輪轉 -->
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <!-- 保留最近 30 個檔案 -->
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <!-- 錯誤日誌檔（只記錄 ERROR 級別） -->
        <RollingFile name="ErrorFile"
                     fileName="logs/error.log"
                     filePattern="logs/error-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN_WITH_LOCATION}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
            <!-- 只記錄 ERROR -->
            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- 你的專案日誌級別 -->
        <Logger name="com.taifex" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
            <AppenderRef ref="ErrorFile"/>
        </Logger>

        <!-- Jsoup 的日誌（只記錄 WARN 以上，避免太吵） -->
        <Logger name="org.jsoup" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <!-- 根日誌設定 -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
            <AppenderRef ref="ErrorFile"/>
        </Root>
    </Loggers>

</Configuration>