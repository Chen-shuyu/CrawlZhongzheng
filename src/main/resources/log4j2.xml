<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <!-- 變數定義 -->
    <Properties>
        <Property name="LOG_PATTERN">
            [%d{yyyy-MM-dd HH:mm:ss}] [%-5level] %msg%n
        </Property>
        <Property name="LOG_PATTERN_WITH_LOCATION">
            [%d{yyyy-MM-dd HH:mm:ss}] [%-5level] [%c{1}:%L] %msg%n
        </Property>
        <!-- 專案名稱 -->
        <Property name="PROJECT_NAME">crawler</Property>
    </Properties>

    <Appenders>
        <!-- 控制台輸出 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!--
            主要日誌檔
            執行時檔案：crawler-20241203-153045.log (程式啟動時建立)
        -->
        <RollingFile name="RollingFile"
                     fileName="logs/${PROJECT_NAME}_${date:yyyyMMddHHmmss}.log"
                     filePattern="logs/${PROJECT_NAME}_%d{yyyyMMdd}_%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <!-- 每天午夜輪轉 -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <!-- 檔案大小超過 50MB 也輪轉 -->
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <!-- 保留最近 30 個壓縮檔 -->
            <DefaultRolloverStrategy max="30">
                <!-- 自動刪除超過 30 天的檔案 -->
                <Delete basePath="logs" maxDepth="1">
                    <IfFileName glob="${PROJECT_NAME}_*.log.gz"/>
                    <IfLastModified age="30d"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!--
            錯誤日誌檔
            執行時檔案：crawler-error-20241203-153045.log
        -->
        <RollingFile name="ErrorFile"
                     fileName="logs/${PROJECT_NAME}_error_${date:yyyyMMddHHmmss}.log"
                     filePattern="logs/${PROJECT_NAME}_error_%d{yyyyMMdd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN_WITH_LOCATION}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30">
                <Delete basePath="logs" maxDepth="1">
                    <IfFileName glob="${PROJECT_NAME}_error_*.log.gz"/>
                    <IfLastModified age="30d"/>
                </Delete>
            </DefaultRolloverStrategy>
            <!-- 只記錄 ERROR -->
            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- 你的專案日誌級別 -->
        <Logger name="com.taifex" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
            <AppenderRef ref="ErrorFile"/>
        </Logger>

        <!-- Jsoup 的日誌（只記錄 WARN 以上） -->
        <Logger name="org.jsoup" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <!-- 根日誌設定 -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
            <AppenderRef ref="ErrorFile"/>
        </Root>
    </Loggers>

</Configuration>